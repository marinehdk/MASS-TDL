	url = https://github.com/google/googletest.git
	branch = v1.17.0

[submodule "tools/third-party/spdlog-1.17.0"]
	path = tools/third-party/spdlog-1.17.0
	url = https://github.com/gabime/spdlog.git
	branch = v1.17.0

[submodule "tools/third-party/yaml-cpp-0.8.0"]
	path = tools/third-party/yaml-cpp-0.8.0
	url = https://github.com/jbeder/yaml-cpp.git
	branch = 0.8.0

[submodule "tools/third-party/geographiclib-2.7"]
	path = tools/third-party/geographiclib-2.7
	url = https://github.com/geographiclib/geographiclib.git
	branch = v2.7

[submodule "tools/third-party/fmt-11.0.2"]
	path = tools/third-party/fmt-11.0.2
