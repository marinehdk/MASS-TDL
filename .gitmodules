[submodule "tools/third-party/casadi-3.7.2"]
	path = tools/third-party/casadi-3.7.2
	url = https://github.com/casadi/casadi.git
	branch = 3.7.2

[submodule "tools/third-party/ipopt-3.14.19"]
	path = tools/third-party/ipopt-3.14.19
