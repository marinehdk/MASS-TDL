# MASS L3 TDL — Dev Docker 镜像（开发者本地容器）
# 详见: docs/Implementation/ci-cd-pipeline.md §4.1
# 镜像: mass-l3/dev:jazzy-ubuntu22.04
# D1.2 修订: Docker 版本固定 — SHA256 + apt 版本 ARG
# 构建命令: docker build --build-arg-file tools/docker/version-lock.txt -f tools/docker/Dockerfile.dev .
ARG ROS_BASE_DIGEST
FROM ros:jazzy-ros-base-noble@${ROS_BASE_DIGEST}

ARG GCC_14_VER
ARG CLANG_TIDY_20_VER
ARG CMAKE_VER
ARG CPPCHECK_VER
ARG PYTHON3_12_VER

# System tools and compilers (与 Dockerfile.ci 同基线)
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        gcc-14=${GCC_14_VER} g++-14=${GCC_14_VER} \
        clang-20=${CLANG_TIDY_20_VER} lld-20=${CLANG_TIDY_20_VER} \
        clang-tidy-20=${CLANG_TIDY_20_VER} clang-format-20=${CLANG_TIDY_20_VER} \
        cmake=${CMAKE_VER} \
        ninja-build \
        ccache \
        git curl wget \
        python3.12=${PYTHON3_12_VER} python3-pip python3-venv \
        lcov gcovr \
        valgrind \
        cppcheck=${CPPCHECK_VER} \
        jq \
        yamllint \
    && rm -rf /var/lib/apt/lists/*

# ===== Dev 专属工具（Dockerfile.ci 不含）=====
RUN apt-get update && apt-get install -y --no-install-recommends \
        gdb \
        lldb-20 \
        strace ltrace \
        tmux htop \
        vim nano \
        less \
        man-db \
        bash-completion \
        sudo \
    && rm -rf /var/lib/apt/lists/*

# Python tools (与 Dockerfile.ci 一致)
RUN pip3 install --no-cache-dir --break-system-packages --ignore-installed \
        colcon-core==0.20.1 \
        colcon-common-extensions \
        ruff==0.6.9 \
        mypy==1.10.1 \
        pytest==8.3.3 \
        pytest-cov==5.0.0 \
        ipython \
        ipdb

# Set GCC 14 as default
RUN update-alternatives --install /usr/bin/gcc gcc /usr/bin/gcc-14 100 && \
    update-alternatives --install /usr/bin/g++ g++ /usr/bin/g++-14 100 && \
    update-alternatives --install /usr/bin/clang clang /usr/bin/clang-20 100 && \
    update-alternatives --install /usr/bin/clang++ clang++ /usr/bin/clang++-20 100

# Source ROS2 environment by default in interactive shells
RUN echo "source /opt/ros/jazzy/setup.bash" >> /etc/bash.bashrc

WORKDIR /workspace
